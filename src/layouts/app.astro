---
import { siteCanonicalUrl } from '@/lib/site';
import { SITE_ICON_LINKS } from '@/lib/site-icons';
import { siteOpenGraph, siteTwitterCard } from '@/lib/site-meta';
import { description, name } from '../../package.json';
import '@/index.css';

if (!Astro.site) {
  throw new Error('Astro `site` must be set (SPEC §5.6)');
}

const canonicalUrl = siteCanonicalUrl(Astro.site);
const og = siteOpenGraph(Astro.site);
const twitter = siteTwitterCard(Astro.site);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />

    <title>{name}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    {
      SITE_ICON_LINKS.map((icon) => (
        <link
          rel={icon.rel}
          href={icon.href}
          sizes={icon.sizes}
          type={icon.type}
        />
      ))
    }

    <meta property="og:type" content={og.type} />
    <meta property="og:locale" content={og.locale} />
    <meta property="og:site_name" content={og.siteName} />
    <meta property="og:title" content={og.title} />
    <meta property="og:description" content={og.description} />
    <meta property="og:url" content={og.url} />
    <meta property="og:image" content={og.image} />
    <meta property="og:image:width" content={String(og.imageWidth)} />
    <meta property="og:image:height" content={String(og.imageHeight)} />
    <meta property="og:image:type" content={og.imageType} />
    <meta property="og:image:alt" content={og.imageAlt} />

    <meta name="twitter:card" content={twitter.card} />
    <meta name="twitter:title" content={twitter.title} />
    <meta name="twitter:description" content={twitter.description} />
    <meta name="twitter:image" content={twitter.image} />
    <meta name="twitter:image:alt" content={twitter.imageAlt} />
  </head>

  <body>
    <slot />
  </body>
</html>
