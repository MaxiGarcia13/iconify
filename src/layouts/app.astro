---
import { capitalize } from '@maxigarcia/js-utils';
import { description, name } from '../../package.json';
import '@/index.css';

if (!Astro.site) {
  throw new Error('Astro `site` must be set (SPEC §5.6)');
}

/** Favicon / Apple Touch / Android Chrome links — SPEC §5.6 table order. */
const SITE_ICON_LINKS: {
  rel: 'icon' | 'apple-touch-icon';
  href: string;
  sizes: string;
  type?: 'image/png';
}[] = [
  { rel: 'icon', href: '/favicon.ico', sizes: 'any' },
  {
    rel: 'icon',
    type: 'image/png',
    sizes: '16x16',
    href: '/favicon-16x16.png',
  },
  {
    rel: 'icon',
    type: 'image/png',
    sizes: '32x32',
    href: '/favicon-32x32.png',
  },
  {
    rel: 'apple-touch-icon',
    sizes: '180x180',
    href: '/apple-touch-icon.png',
  },
  {
    rel: 'apple-touch-icon',
    sizes: '152x152',
    href: '/apple-touch-icon-152x152.png',
  },
  {
    rel: 'apple-touch-icon',
    sizes: '167x167',
    href: '/apple-touch-icon-167x167.png',
  },
  {
    rel: 'apple-touch-icon',
    sizes: '180x180',
    href: '/apple-touch-icon-180x180.png',
  },
  {
    rel: 'icon',
    type: 'image/png',
    sizes: '192x192',
    href: '/android-chrome-192x192.png',
  },
  {
    rel: 'icon',
    type: 'image/png',
    sizes: '512x512',
    href: '/android-chrome-512x512.png',
  },
];

/** Path under `public/` — SPEC §5.6 / §2.4. */
const SITE_OG_IMAGE_PATH = '/og-image.png';
const SITE_OG_IMAGE_WIDTH = 1200;
const SITE_OG_IMAGE_HEIGHT = 630;
const SITE_OG_IMAGE_TYPE = 'image/png';
/** Shared by `og:image:alt` and `twitter:image:alt` (SPEC §5.6). */
const SITE_OG_IMAGE_ALT
  = 'Iconify — high-performance icon set generator preview';

const canonicalUrl = new URL('/', Astro.site).href;
const ogImageUrl = new URL(SITE_OG_IMAGE_PATH, Astro.site).href;

/** SPEC §5.6 — matches `public/site.webmanifest` theme_color / dark canvas. */
const themeColor = '#141826';
const webManifestHref = '/site.webmanifest';
const title = capitalize(name);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="manifest" href={webManifestHref} />

    {
      SITE_ICON_LINKS.map((icon) => (
        <link
          rel={icon.rel}
          href={icon.href}
          sizes={icon.sizes}
          type={icon.type}
        />
      ))
    }

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={title} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(SITE_OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(SITE_OG_IMAGE_HEIGHT)} />
    <meta property="og:image:type" content={SITE_OG_IMAGE_TYPE} />
    <meta property="og:image:alt" content={SITE_OG_IMAGE_ALT} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={SITE_OG_IMAGE_ALT} />
  </head>

  <body>
    <slot />
  </body>
</html>
