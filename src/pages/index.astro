---
import { Generator } from '../components/generator';
import AppLayout from '../layouts/app.astro';
---

<AppLayout>
  <main class="mx-auto flex min-h-dvh w-full max-w-5xl min-w-0 flex-col gap-6 px-4 py-6 pb-[max(1.5rem,env(safe-area-inset-bottom))] sm:gap-8 sm:px-6 sm:py-10">
    <header class="flex min-w-0 flex-col gap-2">
      <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">Iconify</h1>
      <p class="text-muted-foreground text-sm sm:text-base">
        High-performance icon set generator
      </p>
    </header>

    <Generator client:load />
  </main>
</AppLayout>
