---
import Footer from '@/components/footer.astro';
import { Generator } from '@/components/generator';
import AppLayout from '@/layouts/app.astro';

const appIconSrc = '/android-chrome-192x192.png';
---

<AppLayout>
  <main class="mx-auto flex min-h-dvh w-full max-w-5xl min-w-0 flex-col gap-6 px-4 py-6 pb-[max(1.5rem,env(safe-area-inset-bottom))] sm:gap-8 sm:px-6 sm:py-10">
    <header class="flex min-w-0 items-start gap-3 sm:gap-4">
      <img
        src={appIconSrc}
        alt=""
        width="48"
        height="48"
        class="size-10 shrink-0 rounded-xl sm:size-12"
        decoding="async"
      />
      <div class="flex min-w-0 flex-col gap-2">
        <div class="flex min-w-0 flex-col gap-1">
          <h1 class="text-2xl font-semibold tracking-tight sm:text-3xl">Iconify</h1>
          <p class="text-sm font-medium text-muted-foreground sm:text-base">
            High-performance icon set generator
          </p>
        </div>
        <p class="max-w-2xl text-sm leading-relaxed text-muted-foreground">
          Upload one SVG, PNG, or JPG and get a complete icon package for the modern
          web — favicons, Apple Touch icons, Android/PWA assets, Open Graph images,
          plus a copy-paste HTML <code class="font-mono text-[0.9em]">&lt;head&gt;</code> snippet.
        </p>
      </div>
    </header>

    <Generator client:load />

    <Footer />
  </main>
</AppLayout>
