{
  "name": "iconify",
  "type": "module",
  "version": "1.0.16",
  "description": "⚡ High-performance icon set generator. Generate favicons, PWA icons, iOS, and Android assets in seconds.",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/iconify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/iconify.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/iconify/issues"
  },
  "main": "index.js",
  "scripts": {
    "prepare": "simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "start": "node ./dist/server/entry.mjs",
    "clean": "rm -rf dist node_modules .astro",
    "test:unit": "vitest run"
  },
  "dependencies": {
    "@astrojs/node": "^11.0.2",
    "@astrojs/react": "^6.0.1",
    "@astrojs/vercel": "^11.0.3",
    "archiver": "^7.0.1",
    "astro": "^7.1.3",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "sharp": "^0.35.3",
    "to-ico": "^1.1.5"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@maxigarcia/eslint-config": "^1.8.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/archiver": "^7.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/to-ico": "^1.1.3",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "lint-staged": "^17.2.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.3",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,md,astro}": "npm run lint:fix"
  }
}
